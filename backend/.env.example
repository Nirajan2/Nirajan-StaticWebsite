# ──────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to git — it contains your password!
# ──────────────────────────────────────────────────────────────────

# Your Gmail address (the one sending AND receiving the contact emails)
GMAIL_USER=nirajankarki5432@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable "2-Step Verification" if not already on
#   3. Search for "App passwords" → create one (Mail / Windows Computer)
#   4. Paste the 16-character code below (no spaces)
GMAIL_PASS=Nirajankarki1234@#

# Port the server will listen on (3000 is fine for local dev)
PORT=3000

# The email address that will RECEIVE the contact form messages
RECIPIENT_EMAIL=nirajankarki5432@gmail.com

# Allowed frontend origin for CORS (your live site URL, or * for all)
# Example: https://your-portfolio.pages.dev
ALLOWED_ORIGIN=*
